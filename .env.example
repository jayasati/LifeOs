DATABASE_URL="file:./dev.db"
AUTH_SECRET=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres
# DATABASE_URL = POOLED connection (host contains "-pooler"). Add the two
#   query params so PgBouncer + Prisma's serverless adapter play nicely.
# DIRECT_URL   = UNPOOLED connection (no "-pooler" in host). Prisma uses it
#   for `prisma migrate` and `prisma db push` only.
DATABASE_URL="postgresql://neondb_owner:xyz@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://neondb_owner:xyz@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Public origin used for OAuth redirect URIs. In dev keep this as
# http://localhost:3000 (no trailing slash). In prod set to your real domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL must be:
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
